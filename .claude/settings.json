{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && python3 scripts/drift/session_status.py 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Checking substrate drift..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && python3 scripts/drift/run_all.py --stop-on-fail",
            "if": "Bash(git commit:*)",
            "timeout": 60,
            "statusMessage": "Running anti-drift checks before commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && python3 scripts/hooks/post_edit_regen.py || true",
            "timeout": 30,
            "statusMessage": "Regenerating Pages views..."
          }
        ]
      }
    ]
  }
}
